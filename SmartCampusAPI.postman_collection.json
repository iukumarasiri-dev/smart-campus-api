{
  "info": {
    "name": "Smart Campus API — Full Test Suite",
    "_postman_id": "sc-api-full-test-suite-v1",
    "description": "All endpoints and all possible response codes. Run requests TOP TO BOTTOM in order — later tests depend on data created by earlier ones.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "readingId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Part 1 — Discovery",
      "item": [
        {
          "name": "GET / → 200 API Info",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Has name', () => pm.expect(j.name).to.eql('Smart Campus API'));",
                  "pm.test('Has version', () => pm.expect(j.version).to.eql('1.0'));",
                  "pm.test('Has description', () => pm.expect(j).to.have.property('description'));",
                  "pm.test('Has resources with rooms + sensors', () => {",
                  "  pm.expect(j.resources).to.have.property('rooms');",
                  "  pm.expect(j.resources).to.have.property('sensors');",
                  "});",
                  "pm.test('Content-Type is JSON', () => pm.response.to.have.header('Content-Type', /json/));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/" }
          },
          "response": []
        },
        {
          "name": "GET /no-such-endpoint → 404 No Route",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — no matching route', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/no-such-endpoint" }
          },
          "response": []
        }
      ]
    },
